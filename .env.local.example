# Supabase project settings → API. anon key is public-safe (client-side),
# service role key is server-only and bypasses RLS - never expose it to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Used to build the magic-link redirect URL. http://localhost:3000 in dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Akahu Personal App (my.akahu.nz → Developers). Free tier, single-account - 
# fits since every account is joint. Base URL is Akahu's fixed API endpoint
# unless your dashboard showed a different one.
AKAHU_BASE_URL=https://api.akahu.io/v1
AKAHU_APP_TOKEN=
AKAHU_USER_TOKEN=

# --- Not needed until later milestones ---
# ANTHROPIC_API_KEY=
# MARKET_DATA_API_KEY=

# Protects the /api/cron/* routes - Vercel auto-attaches this as the cron's
# Authorization header once it's set as a project env var.
CRON_SECRET=

# Web Push (budget alerts). Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
